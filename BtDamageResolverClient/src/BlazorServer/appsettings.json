{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "LoggingOptions": {
    "LogToConsole": true,
    "LogLevel": "Information",
    "LogLevelOrleans": "Warning"
  },
  "ConnectionStrings": {
    "Redis": "redis:6379,password=PASSWORD"
  },
  "CompressionOptions": {
    "Provider": "Brotli",
    "Quality": 4
  }
}
