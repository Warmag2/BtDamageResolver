@{
    var reminderClass = ComparisonTimeStamp > _updateTimeStamp ? "reminder" : string.Empty;
}

<input class="resolver_input resolver_input_number @reminderClass" type="number" min="@Min" max="@Max" disabled="@Disabled"
    @ref="_inputRef"
    value="@_selectedOption"
    @onfocus="OnFocus"
    @oninput="OnInputChange"
    @onchange="OnInputChange"
    @onblur="CommitEdit"
    @onkeydown="OnKeyDown" />

@code
{
    private int _selectedOption;
    private int _lastParameterValue;
    private DateTime _updateTimeStamp;
    private bool _isBeingEdited;
    private ElementReference _inputRef;

    [Parameter]
    public int SelectedOption { get; set; }

    [Parameter]
    public int Min { get; set; }

    [Parameter]
    public int Max { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public DateTime ComparisonTimeStamp { get; set; }

    [Parameter]
    public EventCallback<int> OnChanged { get; set; }

    public async Task FocusAsync() => await _inputRef.FocusAsync();

    // Suppress re-renders while focused so value="@_selectedOption" doesn't overwrite mid-typing.
    protected override bool ShouldRender() => !_isBeingEdited;

    private void OnFocus() => _isBeingEdited = true;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
            CommitEdit();
    }

    private void OnInputChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var parsed))
        {
            _selectedOption = parsed;
            if (!_isBeingEdited)
                CommitValue(); // unfocused spinner/arrow — commit immediately
        }
    }

    private void CommitValue()
    {
        _selectedOption = Math.Clamp(_selectedOption, Min, Max);
        _updateTimeStamp = DateTime.UtcNow;
        OnChanged.InvokeAsync(_selectedOption);
    }

    private void CommitEdit()
    {
        _isBeingEdited = false;
        CommitValue();
    }

    protected override void OnParametersSet()
    {
        if (SelectedOption != _lastParameterValue)
        {
            _lastParameterValue = SelectedOption;
            _selectedOption = SelectedOption;
        }
    }
}