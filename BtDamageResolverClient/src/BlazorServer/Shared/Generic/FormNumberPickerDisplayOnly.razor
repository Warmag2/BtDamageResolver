@using Faemiyah.BtDamageResolver.Client.BlazorServer.Entities
@using Faemiyah.BtDamageResolver.Client.BlazorServer.Logic
@inject CommonData _commonData

@{
    var numberPrefixString = NumberToDisplay >= 0 ? "+" : string.Empty;
    var numberPrefix = DisplayNumberPrefix ? numberPrefixString : string.Empty;
}

<div class="resolver_div_inputwrapper">
    @if (_editingDirectly)
    {
        <input class="resolver_input resolver_number" type="number" min="@Min" max="@Max" value="@_selectedOption" disabled="@Disabled"
            @onchange="OnDirectInputChange"
            @onblur="CommitDirectEdit"
            @onkeydown="OnKeyDown"
            />
    }
    else
    {
        <span class="resolver_number_picker_display_only @(StyleSelectorDelegate(_selectedOption))" @onclick="StartDirectEdit">@($"{numberPrefix}{NumberToDisplay}")</span>
    }
    
    <button class="resolver_button" disabled="@Disabled" @onclick="Pick">▾</button>

    <div class="resolver_div_picker" style="@VisualStyleController.HideElement(_selectionBoxHidden)">
        @foreach (var option in _options)
        {
            var optionToSelect = option.End;
            if (_selectedOption >= option.Begin && _selectedOption <= option.End)
            {
                <div class="resolver_div_pickeritem active" @onclick="@(e => SelectOptionManual(optionToSelect))">@option.ToString(DisplayNumberPrefix)</div>
            }
            else
            {
                <div class="resolver_div_pickeritem" @onclick="@(e => SelectOptionManual(optionToSelect))">@option.ToString(DisplayNumberPrefix)</div>
            }
        }
    </div>
</div>

@code
{
    private int _selectedOption;
    private bool _selectionBoxHidden = true;
    private bool _editingDirectly = false;
    private List<PickBracket> _options = new();

    [Parameter]
    public Func<List<PickBracket>> BracketCreatorDelegate { get; set; }

    [Parameter]
    public Func<int, string> StyleSelectorDelegate { get; set; }

    [Parameter]
    public int NumberToDisplay { get; set; }

    [Parameter]
    public bool DisplayNumberPrefix { get; set; }

    [Parameter]
    public int Min { get; set; }

    [Parameter]
    public int Max { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Hint { get; set; }

    [Parameter]
    public EventCallback<int> OnChanged { get; set; }

    [Parameter]
    public EventCallback<(string, int)> OnChangedWithHint { get; set; }

    public int SelectedOptionInternal
    {
        get => _selectedOption;
        set
        {
            _selectedOption = value;
            HideSelectionBox();
            OnChanged.InvokeAsync(value);
            OnChangedWithHint.InvokeAsync((Hint, value));
        }
    }

    private void OnDirectInputChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var parsed))
        {
            _selectedOption = parsed;
        }
    }

    private void StartDirectEdit()
    {
        if (!Disabled)
        {
            HideSelectionBox();
            _editingDirectly = true;
        }
    }

    private void CommitDirectEdit()
    {
        _editingDirectly = false;
        SelectedOptionInternal = Math.Clamp(_selectedOption, Min, Max);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
        {
            CommitDirectEdit();
        }
    }

    private void Pick()
    {
        if (_selectionBoxHidden)
        {
            if (!Disabled)
            {
                _options = BracketCreatorDelegate();
                ShowSelectionBox();
            }
        }
        else
        {
            HideSelectionBox();
        }
    }

    private void ShowSelectionBox()
    {
        _selectionBoxHidden = false;
    }

    private void HideSelectionBox()
    {
        _selectionBoxHidden = true;
    }

    protected override void OnInitialized()
    {
        SelectedOptionInternal = NumberToDisplay;
    }

    private void SelectOptionManual(int optionToSelect)
    {
        SelectedOptionInternal = optionToSelect;
    }
}