@using Faemiyah.BtDamageResolver.Client.BlazorServer.Logic

<div class="resolver_div_componentcontainer">
    @if(_enabled)
    {
        @ChildContentEnabled
    }
    else
    {
        @ChildContentDisabled
    }
    <button class="resolver_button_expander @VisualStyleController.GetActiveClass(!_enabled)" @onclick="@(e => _enabled = !_enabled)">
            @if(_enabled)
            {
                <span>
                    &#9654;
                </span>
            }
            else
            {
                <span>
                    &#x25BC;
                </span>
            }
    </button>
</div>

@code
{
    private bool _enabled;

    [Parameter]
    public bool Enabled { get; set; }

    [Parameter]
    public RenderFragment ChildContentEnabled { get; set; }

    [Parameter]
    public RenderFragment ChildContentDisabled { get; set; }

    protected override void OnInitialized()
    {
        _enabled = Enabled;
    }
}