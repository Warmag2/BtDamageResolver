{
  "LoggingOptions": {
    "LogToConsole": true,
    "LogToDatabase": true,
    "LogLevel": "Information",
    "LogLevelOrleans": "Warning",
    "LoggingIntervalMilliseconds": 15000,
    "SendDetailedErrorsToClient": true
  },
  "ClusterOptions": {
    "Invariant": "Npgsql",
    "ConnectionString": "User ID=USERNAME;Password=PASSWORD;Host=orleansdb;Port=5432;Database=BtDamageResolver;SSL Mode=Disable;"
  },
  "CommunicationOptions": {
    "ConnectionString": "redis:6379,password=PASSWORD"
  },
  "CompressionOptions": {
    "Provider": "Brotli",
    "Quality": 4
  }
}
